DJANGO_SECRET_KEY=local-dev-secret-key
DJANGO_ENV=production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=*
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False
DJANGO_SECURE_SSL_REDIRECT=False

## it_asset_management表
MYSQL_DB=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_HOST=
MYSQL_PORT=

## H3C防火墙连接信息
H3C_FW_SYNC_ON_VIEW=False
H3C_FW_ENABLE_TELNET=true
H3C_FW_SYNC_INTERVAL_SECONDS=600
H3C_FW_HOST=
H3C_FW_PORT=
H3C_FW_USERNAME=
H3C_FW_PASSWORD=
H3C_FW_TIMEOUT=8
H3C_FW_INTERFACES=GigabitEthernet0/1,GigabitEthernet0/2,GigabitEthernet0/3
H3C_FW_COMMAND_TIMEOUT=180

## 查询授权明细表
MYSQL_AUTH_HOST=
MYSQL_AUTH_PORT=
MYSQL_AUTH_USER=
MYSQL_AUTH_PASSWORD=
MYSQL_AUTH_DB=
MYSQL_AUTH_LOGIN_TIMEOUT=5
MYSQL_AUTH_QUERY_TIMEOUT=20
MYSQL_AUTH_CHARSET=utf8

## 查询授权结果表
SQLSERVER_AUTH_HOST=
SQLSERVER_AUTH_PORT=
SQLSERVER_AUTH_USER=
SQLSERVER_AUTH_PASSWORD=
SQLSERVER_AUTH_DB=
SQLSERVER_AUTH_LOGIN_TIMEOUT=5
SQLSERVER_AUTH_QUERY_TIMEOUT=20
SQLSERVER_AUTH_CHARSET=utf8
SQLSERVER_AUTH_TDS_VERSION=7.0

## 堡垒机凭证
JUMPSERVER_ACCESS_KEY_ID=
JUMPSERVER_ACCESS_KEY_SECRET=

## 主机资源监控 Prometheus
MONITORING_PROMETHEUS_URL=
MONITORING_REQUEST_TIMEOUT_SECONDS=15
MONITORING_REQUEST_RETRIES=2
ALLOW_INSECURE_UPSTREAM_HTTP=True

# OpenAI-compatible API
MONITORING_AI_ENABLED=True
MONITORING_AI_BASE_URL=
MONITORING_AI_API_KEY=
MONITORING_AI_MODEL=
MONITORING_AI_TIMEOUT_SECONDS=20
MONITORING_AI_MAX_ROWS=120

# SMTP邮件配置
SMTP_SERVER=smtp.qiye.aliyun.com
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
FROM_EMAIL=
FROM_NAME=IT运维管理平台
MONITORING_ALERT_FIXED_CC=

# redis配置
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=
REDIS_DB=6

MONITORING_ALERT_USER_EMAIL_TABLE=BS_DD_USER_BS
MONITORING_ALERT_USER_NAME_COLUMN=name
MONITORING_ALERT_USER_EMAIL_COLUMN=email
MONITORING_DAILY_ALERT_EMAIL_ENABLED=True
MONITORING_DAILY_ALERT_EMAIL_HOUR=9
MONITORING_DAILY_ALERT_EMAIL_MINUTE=0
MONITORING_DAILY_ALERT_THRESHOLD=90

# Auto-start Celery worker+beat when running "python manage.py runserver" (development only).
AUTO_START_CELERY_ON_RUNSERVER=True

PRODUCTION_WEB_BIND_HOST=0.0.0.0
PRODUCTION_WEB_BIND_PORT=8888
